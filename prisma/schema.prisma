generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Household {
  id   String @id @default(cuid())
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  HouseholdMember[]
  accounts Account[]
}

enum HouseholdRole {
  OWNER
  ADULT
  CHILD
}

model HouseholdMember {
  id          String        @id @default(cuid())
  userId      String
  householdId String
  role        HouseholdRole @default(ADULT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
  @@index([userId])
  @@index([householdId])
}

enum BillVisibility {
  PERSONAL
  HOUSEHOLD
}

model Bill {
  id      String   @id @default(cuid())
  name    String
  amount  Decimal
  dueDate DateTime
  isPaid  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@index([userId])
  @@index([dueDate])
  @@index([isPaid])
  @@index([userId, dueDate])
  @@index([userId, isPaid])
}

model User {
  id       String    @id @default(cuid())
  clerkId  String    @unique
  email    String?   @unique
  accounts Account[]
  bills    Bill[]

  firstName String?
  lastName  String?
  imageUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  householdMemberships HouseholdMember[]
}

enum AccountType {
  CHEQUING
  SAVINGS
  CREDIT_CARD
  CASH
  INVESTMENT
  OTHER
}

enum AccountVisibility {
  PERSONAL
  HOUSEHOLD
  BOTH
}

model Account {
  id      String      @id @default(cuid())
  name    String
  type    AccountType
  balance Decimal     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visibility AccountVisibility @default(HOUSEHOLD)
  isArchived Boolean           @default(false)

  ownerId     String? // optional: personal owner
  householdId String // account belongs to this household

  owner     User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@index([householdId])
  @@index([ownerId])
  @@index([visibility])
}

enum TransactionType {
  DEBIT
  CREDIT
  TRANSFER
}

model Transaction {
  id     String          @id @default(cuid())
  name   String
  amount Decimal
  type   TransactionType
  date   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  billId String?
  bill   Bill?   @relation(fields: [billId], references: [id], onDelete: SetNull)

  transferGroupId String?

  @@index([accountId])
  @@index([date])
  @@index([type])
  @@index([accountId, date])
}
